  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "In this test you will be able to control a cube and scale it to fit your
    screen.\n\nThe purpose of this test is to see the ABL or Auto Brightness Limiter
    for your screen. This engages differently for all displays, but generally as
    the cube gets larger it gets dimmer. It may also get dimmer the longer it is
    on screen. \n\nThis is so you can see how different kinds of content even if
    graded to be bright may not appear as bright as it should be.\n\nOLED screens
    can tend to suffer from this the most. it depends on brand, peak brightness and
    model."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
