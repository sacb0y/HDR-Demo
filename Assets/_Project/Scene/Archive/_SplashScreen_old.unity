  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The graph here shows colors ranges based on the RGB color values which
    Unity allows from zero to infinity.\n\nYou will notice SDR and HDR colors are
    split, this is based on the \"paper white\" value. Here paper white is 200 nits,
    and as such is represented by RGB values 1,1,1 for white. Same with the individual
    colors. 5000 nits is 25,25,25. You will notice individual colors have additional
    numbers to them. These are perceptual values, and are theoretical. So while blue
    is 0,0,25, it's perceptual brightness is 361 nits. Different colors have different
    perceptual brightness than pure white. \n\nThese colors may look different depending
    on display and settings: \n\n   \u2022<indent=5%>if you are viewing this on an
    SDR display you may see colors above \"200 nits\" this is cause unity will tone
    map the colors for visibility on SDR displays. An SDR display does not distinguish
    the luminance of the colors, bute software will do it's best to make sure those
    colors are still visible.</indent>\n\n   \u2022<indent=5%>Perceptual brightness
    may vary, some displays do not follow a proper luminance curve. What should be
    1000 nits may look brighter or darker on some displays even if the display is
    capable of it. This is all up to display calibration.</indent>\n\n   \u2022<indent=5%>The
    settings of your display may also play a big role, reducing local dimming settings,
    using dynamic contrast modes, reduced brightness settings etc. Consider looking
    into optimal settings for your display if something seems wrong </indent>\n\n  
    \u2022<indent=5%>You may also want to use the windows HDR calibration tool.</indent>\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
