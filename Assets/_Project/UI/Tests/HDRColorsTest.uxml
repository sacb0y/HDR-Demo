<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xmlns:custom="_Project.Scripts.UI.Elements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Template name="GlobalButtons" src="project://database/Assets/_Project/UI/GlobalButtons.uxml?fileID=9197481963319205126&amp;guid=afd5d21a5d627ab4088425c1c15c9544&amp;type=3#GlobalButtons"/>
    <Style src="project://database/Assets/_Project/UI/UITK%20Templates/HorizontalTab.uss?fileID=7433441132597879392&amp;guid=bec78c1d34c1dc247adfa2176c91712b&amp;type=3#HorizontalTab"/>
    <Style src="project://database/Assets/_Project/UI/Tests/HDRColorTest.uss?fileID=7433441132597879392&amp;guid=f2b555defc47af34aa242ab5057c6c9d&amp;type=3#HDRColorTest"/>
    <ui:VisualElement name="MainContainer" style="flex-grow: 1; padding-top: 38px; background-color: rgba(0, 0, 0, 0); padding-left: 0; position: absolute; align-items: center; align-self: center; top: 0; width: 650px;">
        <ui:VisualElement style="flex-direction: row; height: 60px; align-items: center; padding-left: 0; left: -65px;">
            <ui:Label text="Nits" style="width: 100px; font-size: 30px; color: white; -unity-font-style: bold; margin-right: 20px;"/>
            <ui:VisualElement style="flex-direction: row;">
                <ui:Label text="1" class="nit-label"/>
                <ui:Label text="50" class="nit-label"/>
                <ui:Label text="100" class="nit-label"/>
                <ui:Label text="150" class="nit-label"/>
                <ui:Label text="200" class="nit-label"/>
                <ui:Label text="400" class="nit-label"/>
                <ui:Label text="600" class="nit-label"/>
                <ui:Label text="1000" class="nit-label"/>
                <ui:Label text="1500" class="nit-label"/>
                <ui:Label text="2000" class="nit-label"/>
                <ui:Label text="3000" class="nit-label"/>
                <ui:Label text="4000" class="nit-label"/>
                <ui:Label text="5000" class="nit-label"/>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement style="flex-direction: row; height: 60px; align-items: center; padding-left: 0; margin-top: 43px; left: -65px;">
            <ui:Label text="Value" style="width: 100px; font-size: 30px; color: white; -unity-font-style: bold; margin-right: 20px;"/>
            <ui:VisualElement style="flex-direction: row;">
                <ui:Label text=".005" class="nit-label"/>
                <ui:Label text=".25" class="nit-label"/>
                <ui:Label text=".5" class="nit-label"/>
                <ui:Label text=".75" class="nit-label"/>
                <ui:Label text="1" class="nit-label"/>
                <ui:Label text="2" class="nit-label"/>
                <ui:Label text="3" class="nit-label"/>
                <ui:Label text="5" class="nit-label"/>
                <ui:Label text="7.5" class="nit-label"/>
                <ui:Label text="10" class="nit-label"/>
                <ui:Label text="15" class="nit-label"/>
                <ui:Label text="20" class="nit-label"/>
                <ui:Label text="25" class="nit-label"/>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="SDRHDRLine" style="position: absolute; left: 215px; top: 44px; width: 6px; background-color: rgb(255, 0, 245); align-items: center; justify-content: flex-start; overflow: visible; height: 414px;">
            <ui:Label text="SDR | HDR" class="hdr-line-label" style="padding-left: 6px;"/>
        </ui:VisualElement>
        <ui:VisualElement name="VisualElement" style="position: absolute; width: 150px; right: -220px;">
            <ui:Label text="5000" class="vertical-value"/>
            <ui:Label text="1063" class="vertical-value"/>
            <ui:Label text="361" class="vertical-value"/>
            <ui:Label text="3576" class="vertical-value"/>
        </ui:VisualElement>
    </ui:VisualElement>
    <ui:VisualElement name="Details" style="position: absolute; bottom: 0; height: 265px; width: 1000px; align-items: center; align-self: center;">
        <ui:TabView name="HorizontalTabView" class="HorizontalTabView">
            <ui:Tab label="About">
                <ui:ScrollView>
                    <ui:Label text="The graph here shows colors ranges based on the RGB color values which Unity allows from zero to infinity.&#10;&#10;You will notice SDR and HDR colors are split, this is based on the &quot;paper white&quot; value. Here paper white is 208 nits, and as such is represented by RGB values 1,1,1 for white. Same with the individual colors. 5000 nits is 25,25,25. You will notice individual colors have additional numbers to them. These are perceptual values, and are theoretical. So while blue is 0,0,25, it&apos;s perceptual brightness is 361 nits. Different colors have different perceptual brightness than pure white. &#10;&#10;These colors may look different depending on display and settings: &#10;&#10;   •&lt;indent=5%&gt;if you are viewing this on an SDR display you may see colors above &quot;200 nits&quot; this is cause unity will tone map the colors for visibility on SDR displays. An SDR display does not distinguish the luminance of the colors, bute software will do it&apos;s best to make sure those colors are still visible.&lt;/indent&gt;&#10;&#10;   •&lt;indent=5%&gt;Perceptual brightness may vary, some displays do not follow a proper luminance curve. What should be 1000 nits may look brighter or darker on some displays even if the display is capable of it. This is all up to display calibration.&lt;/indent&gt;&#10;&#10;   •&lt;indent=5%&gt;The settings of your display may also play a big role, reducing local dimming settings, using dynamic contrast modes, reduced brightness settings etc. Consider looking into optimal settings for your display if something seems wrong &lt;/indent&gt;&#10;&#10;   •&lt;indent=5%&gt;You may also want to use the windows HDR calibration tool.&lt;/indent&gt;&#10;" class="description"/>
                </ui:ScrollView>
            </ui:Tab>
            <ui:Tab label="Opinion">
                <ui:Label text="Will add further insights in the future" class="description"/>
            </ui:Tab>
            <ui:Tab label="Settings">
                <ui:VisualElement style="padding: 40px; flex-direction: row; align-items: center;">
                    <custom:UnifiedHDRToggle label="HDR Enabled" name="hdrToggle" style="font-size: 30px; color: white;"/>
                    <ui:Button text="Apply" name="applyButton" style="margin-left: 0; font-size: 24px; position: absolute; bottom: 0; right: 0; left: 0; display: none;"/>
                </ui:VisualElement>
            </ui:Tab>
        </ui:TabView>
    </ui:VisualElement>
    <ui:Instance template="GlobalButtons" style="position: absolute; top: 0; right: 0;"/>
</ui:UXML>
